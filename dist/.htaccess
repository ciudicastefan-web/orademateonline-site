# Ora de Mate Online — reguli servite de LiteSpeed (Astro copiază public/ în dist/)

# Adresele inexistente primesc pagina noastră 404 (nu eroarea seacă a serverului)
ErrorDocument 404 /404.html

# 1) Orice cerere http e împinsă permanent (301) către https —
#    dublăm regula din panoul Hostico ca să nu depindem de setările lui.
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 1b) www → fără www (canonic). Fără asta, cookie-ul de sesiune de pe
#     orademateonline.ro nu se vede pe www. și utilizatorul pare delogat.
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# 2) HSTS: după prima vizită pe https, browserul refuză singur http
#    pentru acest domeniu timp de un an — inclusiv din cache sau bookmarkuri vechi.
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

  # 3) Cache lung pentru asseturile generate de build: numele lor conțin un hash
  #    care se schimbă la fiecare modificare, deci conținutul de sub un nume dat
  #    nu se schimbă NICIODATĂ → browserul le poate ține un an, fără reverificare.
  <FilesMatch "\.[A-Za-z0-9_-]{8,12}\.(css|js|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # 4) Imagini și favicon (nume fixe, se schimbă rar): 30 de zile.
  <FilesMatch "\.(png|jpe?g|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

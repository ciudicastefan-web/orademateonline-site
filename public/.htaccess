# Ora de Mate Online — reguli servite de LiteSpeed (Astro copiază public/ în dist/)

# Adresele inexistente primesc pagina noastră 404 (nu eroarea seacă a serverului)
ErrorDocument 404 /404.html

# Nimeni nu are ce căuta în listarea directoarelor
Options -Indexes

# 1) Orice cerere http e împinsă permanent (301) către https —
#    dublăm regula din panoul Hostico ca să nu depindem de setările lui.
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 1b) www → fără www (canonic). Fără asta, cookie-ul de sesiune de pe
#     orademateonline.ro nu se vede pe www. și utilizatorul pare delogat.
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# 2) HSTS: după prima vizită pe https, browserul refuză singur http
#    pentru acest domeniu timp de un an — inclusiv din cache sau bookmarkuri vechi.
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

  # 2b) Headere de securitate pentru browser:
  #  - CSP: scripturile/stilurile/imaginile pot veni DOAR de pe domeniul nostru;
  #    formularele pot trimite DOAR către noi; site-ul nu poate fi pus în iframe.
  #    ('unsafe-inline' e necesar pentru stilurile inline și confirm()-urile din admin.)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
  #  - browserul nu „ghicește" tipul fișierelor (blochează trucuri cu extensii false)
  Header always set X-Content-Type-Options "nosniff"
  #  - site-ul nu poate fi încadrat în iframe pe alte site-uri (anti-clickjacking)
  Header always set X-Frame-Options "DENY"
  #  - linkurile externe nu primesc adresa completă a paginii de unde pleci
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  #  - site-ul declară că nu folosește cameră/microfon/locație (Meet rulează pe domeniul Google)
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # 3) Cache lung pentru asseturile generate de build: numele lor conțin un hash
  #    care se schimbă la fiecare modificare, deci conținutul de sub un nume dat
  #    nu se schimbă NICIODATĂ → browserul le poate ține un an, fără reverificare.
  <FilesMatch "\.[A-Za-z0-9_-]{8,12}\.(css|js|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # 4) Imagini și favicon (nume fixe, se schimbă rar): 30 de zile.
  <FilesMatch "\.(png|jpe?g|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

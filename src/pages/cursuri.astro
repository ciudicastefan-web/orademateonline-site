---
// Pagina „Cursuri” — schelet: modelul de lucru e stabilit, grupele concrete
// (clase, orar, prețuri) se anunță când se deschid înscrierile.
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Cursuri — Ora de Mate Online"
  description="Grupe mici de matematică online, pe clase, plus materiale de lucru. Înscrierile se deschid în curând."
>
  <main>
    <p class="kicker reveal" style="--i: 0">Cursuri</p>
    <h1 class="reveal" style="--i: 1">Grupe mici, pe clase</h1>

    <p class="lead reveal" style="--i: 2">
      Fiecare grupă are un număr limitat de locuri și elevi din aceeași clasă,
      ca ora să meargă în ritmul potrivit pentru toți. Orele se țin live, online —
      primești linkul de conectare după înscriere.
    </p>

    <div class="steps">
      <div class="step reveal" style="--i: 3">
        <span class="badge-step">Pasul 1</span>
        <h2>Testul de evaluare</h2>
        <p>Gratuit, ~15 minute. Aflăm exact unde are lacune elevul și ce grupă i se potrivește.</p>
      </div>
      <div class="step reveal" style="--i: 4">
        <span class="badge-step">Pasul 2</span>
        <h2>Înscrierea în grupă</h2>
        <p>Alegi grupa pe clasa elevului. Locuri limitate — când se umplu, se deschide lista de așteptare.</p>
      </div>
      <div class="step reveal" style="--i: 5">
        <span class="badge-step">Pasul 3</span>
        <h2>Orele + materialele</h2>
        <p>Ore live în fiecare săptămână, plus fișe de lucru pentru acasă. Progresul se vede în caiet și în note.</p>
      </div>
    </div>

    <div class="twocol reveal" style="--i: 6">
      <div class="panel-box">
        <h2>Cum arată o oră</h2>
        <ul>
          <li>Elevul intră din cont, cu un click pe linkul orei — fără parole de Zoom de căutat prin emailuri.</li>
          <li>Cameră pornită, caiet pe masă: se lucrează efectiv, nu se ascultă pasiv.</li>
          <li>Grupa e mică și e formată doar din elevi de aceeași clasă — nimeni nu rămâne în urmă nevăzut.</li>
          <li>Întrebările sunt încurajate. Aici nimeni nu râde de „întrebarea aia simplă”.</li>
        </ul>
      </div>
      <div class="panel-box">
        <h2>Ce îi trebuie elevului</h2>
        <ul>
          <li>Calculator, laptop sau tabletă cu cameră și microfon</li>
          <li>Internet stabil</li>
          <li>Caiet de matematică și creion — restul vine de la noi</li>
        </ul>
        <p class="hint">Ai întrebări despre desfășurare? <a href="/intrebari-frecvente">Răspunsurile sunt aici →</a></p>
      </div>
    </div>

    <section class="programa reveal" style="--i: 7" aria-label="Ce lucrăm la ore">
      <h2 class="sec-h">Ce lucrăm la ore</h2>
      <p class="sec-sub">
        Ariile mari din programa școlară pe care le acoperim — capitolele exacte se
        aleg după clasa grupei și, la nevoie, după testul de evaluare.
      </p>
      <div class="prog-grid">
        <div class="prog-col">
          <h3>Gimnaziu (V–VIII)</h3>
          <ul>
            <li><strong>Numere și calcule</strong> — naturale, întregi, raționale · puteri și radicali · procente</li>
            <li><strong>Algebră</strong> — calcul algebric · ecuații și inecuații · funcții</li>
            <li><strong>Geometrie plană</strong> — unghiuri, triunghiuri, patrulatere · arii · teorema lui Pitagora · asemănare</li>
            <li><strong>Geometrie în spațiu</strong> — corpuri geometrice · arii și volume</li>
            <li><strong>Organizarea datelor</strong> — medii, grafice, probabilități simple</li>
          </ul>
        </div>
        <div class="prog-col">
          <h3>Liceu (IX–XII)</h3>
          <ul>
            <li><strong>Algebră</strong> — mulțimi și funcții · progresii · ecuații · matrice și determinanți</li>
            <li><strong>Analiză matematică</strong> — limite · derivate · integrale</li>
            <li><strong>Trigonometrie și geometrie</strong> — vectori · aplicații în plan</li>
            <li><strong>Combinatorică și probabilități</strong></li>
            <li><strong>Pregătire Bacalaureat</strong> — pe structura subiectelor, pe profilul fiecăruia</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="cal-sec reveal" style="--i: 8" aria-label="Calendarul orelor">
      <h2 class="sec-h">📅 Calendarul orelor</h2>
      <div id="cal-flash" class="cal-flash" hidden></div>
      <div id="cal-root">
        <p class="cal-note">Se încarcă…</p>
      </div>
    </section>

    <aside class="soon reveal" style="--i: 9">
      🗓️ <strong>Grupele concrete</strong> — pe ce clase, în ce zile, la ce preț —
      se anunță la deschiderea înscrierilor, direct în contul tău.
      <a href="/inregistrare" class="soon-cta">Creează-ți contul</a> ca să le prinzi pe primele.
      Iar dacă vrei ca cel mic să lucreze și singur, între ore:
      <a href="/materiale" class="soon-cta">vezi materialele digitale</a> pe care le pregătim —
      teste rezolvate, exemple pas cu pas, teorie pe scurt.
    </aside>
  </main>
</Layout>

<script>
  /* ── Calendarul orelor: alimentat din aceleași ore pe care adminul le creează.
        Logat → grila pe zile cu locuri libere + înscriere direct de aici.
        Nelogat → invitație la autentificare (cu revenire în această pagină).
        Construit exclusiv cu DOM API + textContent — sigur prin construcție. ── */
  const GRADES = ['Pregătitoare','Clasa I','Clasa a II-a','Clasa a III-a','Clasa a IV-a','Clasa a V-a',
    'Clasa a VI-a','Clasa a VII-a','Clasa a VIII-a','Clasa a IX-a','Clasa a X-a','Clasa a XI-a','Clasa a XII-a'];
  const ROMAN = ['P','I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII'];
  const DAYS = ['Duminică','Luni','Marți','Miercuri','Joi','Vineri','Sâmbătă'];
  const MONTHS = ['ian','feb','mar','apr','mai','iun','iul','aug','sep','oct','nov','dec'];

  /* orele pot fi pe o clasă exactă sau pe o grupă mixtă (interval de clase) */
  const gradeMax = (s: any): number => (s.grade_max ?? s.grade) as number;
  const isMix = (s: any): boolean => gradeMax(s) > s.grade;
  const gradeLabel = (s: any): string =>
    isMix(s) ? `Clasele ${ROMAN[s.grade]}–${ROMAN[gradeMax(s)]} (mix)` : (GRADES[s.grade] ?? '');

  /* prețul orei: „gratuit”, „50 lei”, „49,50 lei” — linkul de conectare se
     deblochează după confirmarea plății (orele gratuite îl au din start) */
  const priceLabel = (cents: number): string => {
    if (!cents || cents <= 0) return 'gratuit';
    if (cents % 100 === 0) return `${cents / 100} lei`;
    return `${(cents / 100).toFixed(2).replace('.', ',')} lei`;
  };

  const root = document.getElementById('cal-root')!;

  function el<K extends keyof HTMLElementTagNameMap>(tag: K, cls?: string, text?: string): HTMLElementTagNameMap[K] {
    const n = document.createElement(tag);
    if (cls) n.className = cls;
    if (text !== undefined) n.textContent = text;
    return n;
  }

  function clearRoot(): void {
    while (root.firstChild) root.removeChild(root.firstChild);
  }

  /* mesajele după înscriere (venim înapoi aici cu ?ok= / ?err=) */
  const FLASH: Record<string, [string, boolean]> = {
    'ok=programat': ['Programare făcută! Linkul orei apare pe cardul ei și în contul tău.', false],
    'ok=programat-plata': ['Loc rezervat! Te contactăm pe email cu detaliile de plată — după confirmare, linkul orei apare aici și în cont.', false],
    'err=programare-plina': ['Ne pare rău, ora s-a umplut între timp.', true],
    'err=programare-dubla': ['Elevul e deja înscris la această oră.', true],
    'err=programare-clasa': ['Ora aleasă e pentru altă clasă decât a elevului.', true],
    'err=programare': ['Programarea nu a putut fi făcută. Încearcă din nou.', true],
    'err=copil-nume': ['Prenumele elevului trebuie să aibă între 2 și 80 de caractere.', true],
    'err=copil-limita': ['Ai atins numărul maxim de profiluri de elevi (6).', true],
    'err=copil-clasa': ['Alege clasa elevului.', true],
  };
  const q = window.location.search.replace('?', '');
  const flashEl = document.getElementById('cal-flash')!;
  for (const key in FLASH) {
    if (q.includes(key)) {
      flashEl.textContent = FLASH[key][0];
      flashEl.classList.toggle('is-err', FLASH[key][1]);
      flashEl.hidden = false;
      history.replaceState(null, '', window.location.pathname);
      flashEl.scrollIntoView({ block: 'center' });
      break;
    }
  }

  function showAnonCta(): void {
    clearRoot();
    const box = el('div', 'cal-cta');
    box.append('Calendarul orelor — cu zilele, locurile libere și înscrierea la un click — e vizibil în cont. ');
    const a1 = el('a', '', 'Autentifică-te');
    a1.setAttribute('href', '/autentificare?next=%2Fcursuri');
    const a2 = el('a', '', 'creează-ți contul gratuit');
    a2.setAttribute('href', '/inregistrare?next=%2Fcursuri');
    box.append(a1, ' sau ', a2, '.');
    root.append(box);
  }

  function noteWithAccountLink(prefix: string, suffix: string): HTMLElement {
    const p = el('p', 'cal-note');
    const a = el('a', '', 'contul tău');
    a.setAttribute('href', '/cont/');
    p.append(prefix, a, suffix);
    return p;
  }

  fetch('/api/sessions.php', { credentials: 'same-origin' })
    .then((r) => (r.status === 401 ? { auth: false } : r.json()))
    .then((data: any) => {
      if (!data || data.auth === false) {
        showAnonCta();
        return;
      }
      render(data);
    })
    .catch(() => {
      clearRoot();
      root.append(el('p', 'cal-note', 'Calendarul nu s-a putut încărca — reîncearcă mai târziu.'));
    });

  function render(data: { children: any[]; sessions: any[] }): void {
    const { children, sessions } = data;
    clearRoot();

    if (!sessions.length) {
      root.append(noteWithAccountLink(
        '📭 Nicio oră programată în următoarele 3 săptămâni — profesoara publică orele aici. Între timp, pregătește ',
        ' (elevul cu prenume + clasă).'
      ));
      return;
    }

    if (!children.length) {
      root.append(noteWithAccountLink(
        '💡 Nu ai încă un elev în cont — apasă „Înscrie un elev nou” direct pe ora potrivită și completezi datele lui pe loc, sau adaugă-l din ',
        '.'
      ));
    }

    const byDay = new Map<string, any[]>();
    for (const s of sessions) {
      const key = String(s.starts_at).slice(0, 10);
      if (!byDay.has(key)) byDay.set(key, []);
      byDay.get(key)!.push(s);
    }

    const strip = el('div', 'cal-strip');
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    for (let i = 0; i < 14; i++) {
      const d = new Date(today.getTime() + i * 86400000);
      const key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
      const daySessions = byDay.get(key) || [];
      const isToday = i === 0;

      const col = el('div', 'cal-day' + (isToday ? ' today' : ''));
      const head = el('div', 'cal-day-h', DAYS[d.getDay()]);
      head.append(el('span', '', `${d.getDate()} ${MONTHS[d.getMonth()]}${isToday ? ' · AZI' : ''}`));
      col.append(head);

      if (!daySessions.length) col.append(el('div', 'cal-empty', '—'));

      for (const s of daySessions) {
        const full = s.free <= 0;
        const enrolled = s.enrolled_children.length > 0;
        const matching = children.filter((c: any) => c.grade >= s.grade && c.grade <= gradeMax(s));

        const card = el('div', 'cal-card' + (enrolled ? ' mine' : ''));
        card.append(el('div', 'cal-time', `${String(s.starts_at).slice(11, 16)} · ${s.duration} min`));
        card.append(el('div', 'cal-title', String(s.title)));

        const awaitingPay = enrolled && (s.unpaid_children || []).length > 0 && !s.meet_link;

        const meta = el('div', 'cal-meta');
        meta.append(el('span', 'cal-pill grade', gradeLabel(s)));
        meta.append(el('span', 'cal-pill price', priceLabel(s.price_cents)));
        if (awaitingPay) meta.append(el('span', 'cal-pill full', 'rezervat · de achitat'));
        else if (enrolled) meta.append(el('span', 'cal-pill ok', 'înscris ✓'));
        else if (full) meta.append(el('span', 'cal-pill full', 'complet'));
        else meta.append(el('span', 'cal-pill', `${s.free} ${s.free === 1 ? 'loc liber' : 'locuri libere'}`));
        card.append(meta);

        if (awaitingPay) {
          card.append(el('div', 'cal-hint', 'îți confirmăm plata pe email — apoi primești linkul orei'));
        }

        if (enrolled && s.meet_link) {
          const join = el('a', 'cal-join', 'Intră la oră →');
          join.setAttribute('href', String(s.meet_link));
          join.setAttribute('rel', 'noopener');
          card.append(join);
        }

        if (!enrolled && !full && matching.length > 0) {
          const form = el('form', 'cal-enroll');
          form.setAttribute('method', 'post');
          form.setAttribute('action', '/api/book.php');
          const h1 = el('input'); h1.type = 'hidden'; h1.name = 'session_id'; h1.value = String(s.id);
          const h2 = el('input'); h2.type = 'hidden'; h2.name = 'back'; h2.value = '/cursuri';
          form.append(h1, h2);
          const paid = s.price_cents > 0;
          if (matching.length === 1) {
            const h3 = el('input'); h3.type = 'hidden'; h3.name = 'child_id'; h3.value = String(matching[0].id);
            form.append(h3, el('button', '',
              paid ? `Rezervă pentru ${matching[0].name} — ${priceLabel(s.price_cents)}` : `Înscrie-l pe ${matching[0].name}`));
          } else {
            const sel = el('select'); sel.name = 'child_id';
            for (const c of matching) {
              const opt = el('option', '', String(c.name));
              opt.value = String(c.id);
              sel.append(opt);
            }
            form.append(sel, el('button', '', paid ? `Rezervă — ${priceLabel(s.price_cents)}` : 'Înscrie'));
          }
          card.append(form);
        }

        if (!enrolled && !full && matching.length === 0) {
          // fără elev pe clasa orei: formularul de elev (ca în cont) chiar pe card —
          // clasa o preia automat de la oră, apoi înscrierea se face în același pas
          if (children.length > 0) card.append(el('div', 'cal-hint', 'elevii tăi sunt pe altă clasă'));
          const det = el('details', 'cal-add');
          det.append(el('summary', '', '➕ Înscrie un elev nou'));
          const form = el('form', 'cal-enroll');
          form.setAttribute('method', 'post');
          form.setAttribute('action', '/api/book.php');
          const h1 = el('input'); h1.type = 'hidden'; h1.name = 'session_id'; h1.value = String(s.id);
          const h2 = el('input'); h2.type = 'hidden'; h2.name = 'back'; h2.value = '/cursuri';
          const nameIn = el('input');
          nameIn.type = 'text'; nameIn.name = 'new_child_name';
          nameIn.placeholder = 'Prenumele elevului';
          nameIn.required = true; nameIn.minLength = 2; nameIn.maxLength = 80;
          const schoolIn = el('input');
          schoolIn.type = 'text'; schoolIn.name = 'new_child_school';
          schoolIn.placeholder = 'Școala (opțional)'; schoolIn.maxLength = 160;
          form.append(h1, h2, nameIn, schoolIn);
          if (isMix(s)) {
            // grupă mixtă: părintele alege clasa elevului din intervalul orei
            const gradeSel = el('select'); gradeSel.name = 'new_child_grade'; gradeSel.required = true;
            const ph = el('option', '', 'Clasa elevului…');
            ph.value = ''; ph.disabled = true; ph.selected = true;
            gradeSel.append(ph);
            for (let g = s.grade; g <= gradeMax(s); g++) {
              const opt = el('option', '', GRADES[g] ?? '');
              opt.value = String(g);
              gradeSel.append(opt);
            }
            form.append(gradeSel);
          } else {
            form.append(el('div', 'cal-add-note', `Îl trecem automat la ${GRADES[s.grade] ?? 'clasa orei'}.`));
          }
          form.append(el('button', '',
            s.price_cents > 0 ? `Adaugă elevul și rezervă — ${priceLabel(s.price_cents)}` : 'Adaugă elevul și înscrie-l'));
          det.append(form);
          card.append(det);
        }

        col.append(card);
      }
      strip.append(col);
    }
    root.append(strip);
  }
</script>

<style>
  .kicker {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--pen);
  }

  h1 {
    margin-top: 10px;
    font-size: clamp(1.9rem, 5vw, 3rem);
  }

  .lead {
    margin-top: 18px;
    max-width: 58ch;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .steps {
    margin-top: clamp(32px, 5vh, 48px);
    display: grid;
    gap: 18px;
  }

  @media (min-width: 760px) {
    .steps {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .step {
    background: var(--card);
    border: 1px solid rgba(43, 74, 139, 0.14);
    border-radius: 14px;
    padding: 24px;
    box-shadow: 0 3px 16px rgba(29, 46, 82, 0.06);
  }

  .badge-step {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pen);
    border: 1.5px solid rgba(228, 87, 46, 0.45);
    border-radius: 999px;
    padding: 4px 12px;
  }

  .step h2 {
    margin-top: 14px;
    font-family: 'Fraunces Variable', serif;
    font-weight: 600;
    font-size: 1.18rem;
  }

  .step p {
    margin-top: 8px;
    line-height: 1.6;
    color: var(--ink-soft);
    font-size: 0.98rem;
  }

  .soon {
    margin-top: 30px;
    max-width: 640px;
    padding: 18px 22px;
    border-radius: 12px;
    border: 1.5px dashed rgba(228, 87, 46, 0.5);
    background: rgba(228, 87, 46, 0.05);
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .soon strong {
    color: var(--ink);
  }

  .soon-cta {
    color: var(--pen);
    font-weight: 700;
  }

  .twocol {
    margin-top: clamp(32px, 5vh, 48px);
    display: grid;
    gap: 18px;
  }

  @media (min-width: 760px) {
    .twocol { grid-template-columns: 1fr 1fr; }
  }

  .panel-box {
    background: var(--card);
    border: 1px solid rgba(43, 74, 139, 0.14);
    border-radius: 14px;
    padding: 24px;
    box-shadow: 0 3px 16px rgba(29, 46, 82, 0.06);
  }

  .panel-box h2 {
    font-family: 'Fraunces Variable', serif;
    font-weight: 600;
    font-size: 1.18rem;
  }

  .panel-box ul {
    margin: 12px 0 0 20px;
    display: grid;
    gap: 8px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .panel-box .hint {
    margin-top: 14px;
    font-size: 0.92rem;
    color: var(--ink-soft);
  }

  .panel-box .hint a {
    color: var(--pen);
    font-weight: 700;
  }

  /* ── Programa ── */
  .sec-h {
    margin-top: clamp(40px, 6vh, 60px);
    font-family: 'Fraunces Variable', serif;
    font-weight: 600;
    font-size: clamp(1.4rem, 3vw, 1.8rem);
  }

  .sec-sub {
    margin-top: 8px;
    max-width: 62ch;
    line-height: 1.65;
    color: var(--ink-soft);
  }

  .prog-grid {
    margin-top: 20px;
    display: grid;
    gap: 18px;
  }

  @media (min-width: 760px) {
    .prog-grid { grid-template-columns: 1fr 1fr; }
  }

  .prog-col {
    background: var(--card);
    border: 1px solid rgba(43, 74, 139, 0.14);
    border-radius: 14px;
    padding: 24px;
    box-shadow: 0 3px 16px rgba(29, 46, 82, 0.06);
  }

  .prog-col h3 {
    font-family: 'Fraunces Variable', serif;
    font-weight: 600;
    font-size: 1.12rem;
    color: var(--pen);
  }

  .prog-col ul {
    margin: 12px 0 0 20px;
    display: grid;
    gap: 10px;
    line-height: 1.55;
    color: var(--ink-soft);
    font-size: 0.97rem;
  }

  .prog-col strong { color: var(--ink); }

  /* ── Calendarul orelor ── */
  .cal-flash {
    margin-top: 16px;
    padding: 12px 16px;
    border-radius: 10px;
    font-weight: 700;
    background: rgba(46, 139, 87, 0.12);
    border: 1.5px solid rgba(46, 139, 87, 0.4);
    color: #1e5c38;
  }

  .cal-flash.is-err {
    background: rgba(228, 87, 46, 0.08);
    border-color: rgba(228, 87, 46, 0.4);
    color: #9c3415;
  }

  #cal-root { margin-top: 16px; }

  .cal-sec :global(.cal-note) {
    padding: 16px 18px;
    border-radius: 12px;
    background: var(--card);
    border: 1px solid rgba(43, 74, 139, 0.14);
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .cal-sec :global(.cal-note a),
  .cal-sec :global(.cal-cta a) {
    color: var(--pen);
    font-weight: 700;
  }

  .cal-sec :global(.cal-cta) {
    padding: 18px 22px;
    border-radius: 12px;
    border: 1.5px dashed rgba(43, 74, 139, 0.35);
    background: rgba(43, 74, 139, 0.04);
    line-height: 1.65;
    color: var(--ink-soft);
  }

  /* banda cu zile: derulabilă orizontal, ca un orar */
  .cal-sec :global(.cal-strip) {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(168px, 1fr);

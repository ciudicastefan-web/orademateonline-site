---
// Pagina „Contact” — schelet: adresa oficială și formularul se activează
// la lansare (căsuța de email + endpoint-ul de formular nu există încă).
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — Ora de Mate Online"
  description="Contactează Ora de Mate Online. Adresa de email și formularul de contact se activează la lansare."
>
  <main>
    <p class="kicker reveal" style="--i: 0">Contact</p>
    <h1 class="reveal" style="--i: 1">Hai să vorbim</h1>

    <p class="lead reveal" style="--i: 2">
      Ai întrebări despre grupe, despre cum se desfășoară orele sau despre ce i
      s-ar potrivi copilului tău? Exact pentru asta va fi pagina asta.
    </p>

    <aside class="soon reveal" style="--i: 3">
      ✉️ <strong>Adresa de email și formularul de contact se activează la lansare</strong>
      — împreună cu testul de evaluare gratuit și cu anunțul primelor grupe.
      Mulțumim pentru răbdare!
    </aside>
  </main>
</Layout>

<style>
  .kicker {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--pen);
  }

  h1 {
    margin-top: 10px;
    font-size: clamp(1.9rem, 5vw, 3rem);
  }

  .lead {
    margin-top: 18px;
    max-width: 58ch;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .soon {
    margin-top: 30px;
    max-width: 640px;
    padding: 18px 22px;
    border-radius: 12px;
    border: 1.5px dashed rgba(228, 87, 46, 0.5);
    background: rgba(228, 87, 46, 0.05);
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .soon strong {
    color: var(--ink);
  }
</style>

---
// Autentificare (login) — mesajele de stare vin prin parametrii din URL.
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Autentificare — Ora de Mate Online"
  description="Intră în contul tău Ora de Mate Online."
>
  <main>
    <p class="kicker reveal" style="--i: 0">Cont</p>
    <h1 class="reveal" style="--i: 1">Bine ai revenit</h1>

    <div id="flash" class="flash" hidden></div>

    <form class="panel reveal" style="--i: 2" method="post" action="/api/login.php">
      <label>
        Email
        <input type="email" name="email" required maxlength="190" autocomplete="email" />
      </label>
      <label>
        Parolă
        <input type="password" name="password" required autocomplete="current-password" />
      </label>
      <button type="submit">Intră în cont</button>
      <p class="alt">
        Nu ai cont? <a href="/inregistrare">Creează unul</a>
        &nbsp;·&nbsp; <a href="/resetare">Ai uitat parola?</a>
      </p>
    </form>
  </main>
</Layout>

<script>
  // Dacă ești deja logat, pagina de login nu are ce să-ți arate — te duce la cont.
  fetch('/api/me.php', { credentials: 'same-origin' })
    .then((r) => (r.ok ? r.json() : null))
    .then((me) => {
      if (me && me.auth) window.location.replace('/cont/');
    })
    .catch(() => {});

  const MSG: Record<string, [string, boolean]> = {
    'ok=confirmare': ['Aproape gata! Ți-am trimis un email de activare — dă click pe linkul din el (verifică și spamul).', false],
    'ok=activat': ['Contul e activat! Te poți autentifica.', false],
    'err=token': ['Linkul de activare e invalid sau expirat. Înregistrează-te din nou pentru a primi altul.', true],
    'err=exista': ['Există deja un cont cu acest email. Autentifică-te mai jos.', true],
    'err=gresit': ['Email sau parolă greșită.', true],
    'err=blocat': ['Cont blocat temporar după prea multe încercări. Reîncearcă peste 15 minute.', true],
    'err=neactivat': ['Contul nu e activat încă — caută emailul de activare (și în spam).', true],
    'ok=reset-trimis': ['Dacă emailul există în sistem, ți-am trimis un link de resetare (valabil 1 oră).', false],
    'ok=parola-schimbata': ['Parola a fost schimbată! Te poți autentifica cu cea nouă.', false],
    'err=reset-token': ['Linkul de resetare e invalid sau expirat. Cere unul nou de la „Ai uitat parola?".', true],
    'err=blocat-admin': ['Acest cont a fost suspendat. Pentru detalii, contactează-ne.', true],
  };
  const q = window.location.search.replace('?', '');
  const flash = document.getElementById('flash')!;
  for (const key in MSG) {
    if (q.includes(key)) {
      flash.textContent = MSG[key][0];
      flash.classList.toggle('is-err', MSG[key][1]);
      flash.hidden = false;
      break;
    }
  }
</script>

<style>
  .kicker {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--pen);
  }

  h1 {
    margin-top: 10px;
    font-size: clamp(1.9rem, 5vw, 2.8rem);
  }

  .flash {
    margin-top: 22px;
    max-width: 440px;
    padding: 14px 18px;
    border-radius: 12px;
    border: 1.5px dashed rgba(43, 74, 139, 0.4);
    background: rgba(43, 74, 139, 0.06);
    line-height: 1.5;
  }

  .flash.is-err {
    border-color: rgba(228, 87, 46, 0.55);
    background: rgba(228, 87, 46, 0.07);
  }

  .panel {
    margin-top: 26px;
    max-width: 440px;
    background: var(--card);
    border: 1px solid rgba(43, 74, 139, 0.14);
    border-radius: 14px;
    padding: 28px;
    box-shadow: 0 3px 16px rgba(29, 46, 82, 0.06);
    display: grid;
    gap: 18px;
  }

  label {
    display: grid;
    gap: 6px;
    font-weight: 700;
    font-size: 0.95rem;
  }

  input {
    font: inherit;
    font-weight: 400;
    padding: 11px 14px;
    border-radius: 10px;
    border: 1.5px solid rgba(43, 74, 139, 0.25);
    background: #fff;
    color: var(--ink);
  }

  input:focus-visible {
    outline: 2px solid var(--pen);
    outline-offset: 1px;
  }

  button {
    font: inherit;
    font-weight: 700;
    padding: 13px 18px;
    border: none;
    border-radius: 999px;
    background: var(--ink);
    color: var(--paper);
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease;
  }

  button:hover {
    background: var(--pen);
    transform: translateY(-1px);
  }

  .alt {
    font-size: 0.92rem;
    color: var(--ink-soft);
    text-align: center;
  }

  .alt a {
    color: var(--pen);
    font-weight: 700;
  }
</style>

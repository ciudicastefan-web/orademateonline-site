---
// Pagina „Materiale” — catalog de prezentare, public pentru toți.
// Fiecare material: card cu buton Cumpără + buton info (ℹ) care deschide un
// POPOVER mic, lipit de card (nu modal peste toată pagina).
// „Cumpără”: nelogat → login/înregistrare cu revenire aici; logat → notă „în curând”.
// Textele din `info` sunt PLACEHOLDER — se editează pe măsură ce urcăm materialele.
import Layout from '../layouts/Layout.astro';

type Material = {
  id: string;
  title: string;
  meta: string;
  price: string;
  tags: string[];
  info: string;
};

type Group = { key: string; label: string; note?: string; items: Material[] };

const groups: Group[] = [
  {
    key: 'gimnaziu',
    label: 'Gimnaziu (clasele V–VIII)',
    note: 'Teste, exemple și teorie pe fiecare clasă și capitol.',
    items: [
      {
        id: 'g5-teste',
        title: 'Teste rezolvate — Clasa a V-a',
        meta: 'PDF · teste pe capitole · rezolvări complete',
        price: 'în curând',
        tags: ['Clasa a V-a', 'Teste'],
        info: 'Culegere de teste pe capitolele clasei a V-a (numere naturale, fracții, unități de măsură, geometrie de bază), fiecare cu barem și rezolvare completă pas cu pas. Ideal pentru pregătirea tezelor și verificarea temelor acasă. (Text de prezentare provizoriu — se completează la încărcarea materialului.)',
      },
      {
        id: 'g6-exemple',
        title: 'Exemple rezolvate pas cu pas — Clasa a VI-a',
        meta: 'PDF · probleme-tip explicate',
        price: 'în curând',
        tags: ['Clasa a VI-a', 'Exemple'],
        info: 'Probleme-tip din programa clasei a VI-a (rapoarte și proporții, numere întregi, unghiuri), fiecare explicată ca la oră: ce se cere, de unde pornești, cum gândești fiecare pas. (Text de prezentare provizoriu.)',
      },
      {
        id: 'g7-teorie',
        title: 'Teorie pe scurt — Clasa a VII-a',
        meta: 'PDF · fișe de sinteză',
        price: 'în curând',
        tags: ['Clasa a VII-a', 'Teorie'],
        info: 'Fișe de sinteză cu formulele și regulile esențiale ale clasei a VII-a (calcul algebric, teorema lui Pitagora, arii) — de pus lângă caiet la teme și înainte de teste. (Text de prezentare provizoriu.)',
      },
      {
        id: 'g8-teste',
        title: 'Teste rezolvate — Clasa a VIII-a',
        meta: 'PDF · pe capitole · rezolvări complete',
        price: 'în curând',
        tags: ['Clasa a VIII-a', 'Teste'],
        info: 'Teste pe capitolele clasei a VIII-a, cu rezolvări detaliate — o pregătire solidă și pentru materia curentă, și ca punte spre Evaluarea Națională. (Text de prezentare provizoriu.)',
      },
    ],
  },
  {
    key: 'evaluare',
    label: 'Evaluarea Națională & trecerea în clasa a IX-a',
    note: 'Pentru clasa a VIII-a: recapitulare, modele de subiecte, admitere la liceu.',
    items: [
      {
        id: 'en-modele',
        title: 'Modele de subiecte — Evaluarea Națională',
        meta: 'PDF · pe structura oficială · rezolvări',
        price: 'în curând',
        tags: ['Clasa a VIII-a', 'Evaluarea Națională'],
        info: 'Variante de subiecte construite pe structura oficială a Evaluării Naționale, cu rezolvări complete și barem — pentru antrenament în condiții cât mai apropiate de examen. (Text de prezentare provizoriu.)',
      },
      {
        id: 'en-recap',
        title: 'Recapitulare completă gimnaziu',
        meta: 'PDF · toată materia de EN, condensată',
        price: 'în curând',
        tags: ['Clasa a VIII-a', 'Recapitulare'],
        info: 'Sinteza întregii materii de gimnaziu relevante pentru Evaluarea Națională, organizată pe capitole, cu exemple rezolvate — pentru recapitularea de dinaintea examenului. (Text de prezentare provizoriu.)',
      },
      {
        id: 'en-punte',
        title: 'Puntea spre clasa a IX-a',
        meta: 'PDF · ce trebuie să știe înainte de liceu',
        price: 'în curând',
        tags: ['Trecere VIII → IX', 'Admitere'],
        info: 'Ce concepte de gimnaziu se folosesc din prima în clasa a IX-a și cum arată saltul spre matematica de liceu — pentru un start fără goluri. (Text de prezentare provizoriu.)',
      },
    ],
  },
  {
    key: 'liceu',
    label: 'Liceu & Bacalaureat',
    note: 'Pe programa de liceu, cu sinteze și teste pentru BAC.',
    items: [
      {
        id: 'l9-teorie',
        title: 'Teorie + exemple — Clasa a IX-a',
        meta: 'PDF · mulțimi, funcții, trigonometrie',
        price: 'în curând',
        tags: ['Clasa a IX-a', 'Teorie'],
        info: 'Teoria esențială a clasei a IX-a cu exemple rezolvate — pentru saltul de la gimnaziu la rigoarea liceului. (Text de prezentare provizoriu.)',
      },
      {
        id: 'bac-modele',
        title: 'Modele de subiecte — Bacalaureat',
        meta: 'PDF · pe profiluri · rezolvări detaliate',
        price: 'în curând',
        tags: ['Bacalaureat', 'Teste'],
        info: 'Variante de subiecte pe structura probei de matematică la BAC, cu rezolvări detaliate — pentru toate profilurile. Materialele indică profilul căruia i se adresează. (Text de prezentare provizoriu.)',
      },
      {
        id: 'bac-sinteze',
        title: 'Sinteze pentru Bacalaureat',
        meta: 'PDF · formulele care pică la examen',
        price: 'în curând',
        tags: ['Bacalaureat', 'Teorie'],
        info: 'Formularul complet de care ai nevoie la BAC, condensat pe capitole, cu exemplul-tip pentru fiecare formulă. (Text de prezentare provizoriu.)',
      },
    ],
  },
];
---

<Layout
  title="Materiale digitale — Ora de Mate Online"
  description="Catalog de materiale digitale de matematică: teste cu rezolvări, exemple pas cu pas, teorie, Evaluarea Națională și Bacalaureat, pe clase. PDF descărcabile."
>
  <main>
    <p class="kicker reveal" style="--i: 0">Materiale digitale</p>
    <h1 class="reveal" style="--i: 1">Catalogul de materiale</h1>
    <p class="lead reveal" style="--i: 2">
      Teste cu rezolvări complete, exemple lucrate pas cu pas și teorie pe scurt —
      în format PDF, organizate pe clase, de la gimnaziu la Bacalaureat. Apasă pe
      <strong>ℹ️</strong> la orice material ca să vezi exact ce conține.
    </p>
    <p class="notice reveal" style="--i: 3">
      🛒 <strong>Magazinul se deschide în curând.</strong> Prețurile și primele titluri
      se anunță la lansare — <a href="/inregistrare?next=%2Fmateriale">creează-ți contul</a> ca să afli primul.
    </p>

    {groups.map((g, gi) => (
      <section class="group reveal" style={`--i: ${gi + 4}`} aria-label={g.label}>
        <div class="group-head">
          <h2>{g.label}</h2>
          {g.note && <p>{g.note}</p>}
        </div>
        <div class="items">
          {g.items.map((m) => (
            <article class="item">
              <div class="item-tags">
                {m.tags.map((t) => <span class="tag">{t}</span>)}
              </div>
              <h3>{m.title}</h3>
              <p class="item-meta">{m.meta}</p>
              <div class="item-foot">
                <span class="price">{m.price}</span>
                <div class="actions">
                  <button type="button" class="info-btn" aria-expanded="false"
                          aria-label={`Detalii despre ${m.title}`}>ℹ️</button>
                  <a class="buy" href="/autentificare?next=%2Fmateriale">Cumpără</a>
                </div>
              </div>
              <div class="pop" hidden>
                <p class="pop-kicker">Ce vei găsi în material</p>
                <p class="pop-text">{m.info}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}

    <aside class="soon reveal" style="--i: 8">
      Nu găsești ce cauți sau ai nevoie de un material pe un capitol anume?
      <a href="/contact">Scrie-ne</a> — construim catalogul și după cererile părinților.
    </aside>
  </main>

  <!-- bulă mică pentru utilizatorii logați care apasă Cumpără înainte de lansare -->
  <div id="buy-note" hidden>
    🛒 Magazinul se deschide în curând — după cumpărare, materialul va apărea automat
    la „Materialele mele”, în contul tău.
  </div>
</Layout>

<script>
  /* Popover-ul de info: mic, lipit de card, câte unul deschis o dată. */
  const items = Array.from(document.querySelectorAll<HTMLElement>('.item'));

  function closeAll() {
    for (const it of items) {
      (it.querySelector('.pop') as HTMLElement).hidden = true;
      (it.querySelector('.info-btn') as HTMLElement).setAttribute('aria-expanded', 'false');
    }
    buyNote.hidden = true;
  }

  for (const it of items) {
    const btn = it.querySelector('.info-btn') as HTMLButtonElement;
    const pop = it.querySelector('.pop') as HTMLElement;
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const willOpen = pop.hidden;
      closeAll();
      pop.hidden = !willOpen;
      btn.setAttribute('aria-expanded', String(willOpen));
    });
  }

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.pop')) closeAll();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAll();
  });

  /* Butonul Cumpără: nelogat → login cu revenire aici (href-ul implicit);
     logat → bulă informativă lângă buton, până se deschide magazinul. */
  const buyNote = document.getElementById('buy-note') as HTMLElement;
  let authed = false;
  fetch('/api/me.php', { credentials: 'same-origin' })
    .then((r) => (r.ok ? r.json() : null))
    .then((me) => { authed = !!(me && me.auth); })
    .catch(() => {});

  document.querySelectorAll<HTMLAnchorElement>('.buy').forEach((a) => {
    a.addEventListener('click', (e) => {
      if (!authed) return; // merge natural la /autentificare?next=/materiale
      e.preventDefault();
      e.stopPropagation();
      closeAll();
      const r = a.getBoundingClientRect();
      buyNote.style.top = window.scrollY + r.bottom + 10 + 'px';
      buyNote.style.left = Math.max(12, Math.min(window.innerWidth - 312, r.right - 300)) + 'px';
      buyNote.hidden = false;
    });
  });
</script>

<style>
  .kicker { font-size: 0.9rem; font-weight: 700; letter-spacing: 0.32em; text-transform: uppercase; color: var(--pen); }
  h1 { margin-top: 10px; font-size: clamp(1.9rem, 5vw, 3rem); }
  .lead { margin-top: 16px; max-width: 62ch; font-size: 1.06rem; line-height: 1.7; color: var(--ink-soft); }
  .lead strong { color: var(--ink); }

  .notice {
    margin-top: 18px;
    max-width: 640px;
    padding: 14px 18px;
    border-radius: 12px;
    border: 1.5px dashed rgba(228, 87, 46, 0.5);
    background: rgba(228, 87, 46, 0.05);
    line-height: 1.6;
    color: var(--ink-soft);
  }
  .notice strong { color: var(--ink); }
  .notice a { color: var(--pen); font-weight: 700; }

  .group { margin-top: clamp(36px, 6vh, 56px); }

  .group-head h2 {
    font-family: 'Fraunces Variable', serif;
    font-weight: 600;
    font-size: clamp(1.3rem, 3vw, 1.7rem);
  }
  .group-head p { margin-top: 4px; color: var(--ink-soft); }

  .items {
    margin-top: 18px;
    display: grid;
    gap: 16px;
  }
  @media (min-width: 680px) { .items { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1040px) { .items { grid-template-columns: repeat(3, 1fr); } }

  .item {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--card);
    border: 1px solid rgba(43, 74, 139, 0.14);
    border-radius: 14px;
    padding: 20px 20px 18px;
    box-shadow: 0 3px 16px rgba(29, 46, 82, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .item:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 26px rgba(29, 46, 82, 0.1);
  }

  .item-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
  .tag {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(43, 74, 139, 0.08);
    color: var(--ink-soft);
  }

  .item h3 {
    font-family: 'Fraunces Variable', serif;
    font-weight: 600;
    font-size: 1.12rem;
    line-height: 1.3;
  }
  .item-meta { margin-top: 6px; color: var(--ink-soft); font-size: 0.9rem; flex: 1; }

  .item-foot {
    margin-top: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .price { font-weight: 700; color: var(--pen); font-size: 0.9rem; }
  .actions { display: flex; align-items: center; gap: 8px; }

  .info-btn {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1.5px solid rgba(43, 74, 139, 0.25);
    background: #fff;
    cursor: pointer;
    font-size: 0.95rem;
    line-height: 1;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .info-btn:hover, .info-btn[aria-expanded='true'] { border-color: var(--pen); transform: scale(1.08); }

  .buy {
    font: inherit;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 9px 18px;
    border-radius: 999px;
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .buy:hover { background: var(--pen); }

  /* popover-ul de info: mic, ancorat pe card, deasupra footerului cardului */
  .pop {
    position: absolute;
    left: 10px;
    right: 10px;
    bottom: calc(100% - 8px);
    background: var(--card);
    border: 1.5px solid rgba(228, 87, 46, 0.35);
    border-radius: 12px;
    padding: 16px 18px;
    box-shadow: 0 14px 34px rgba(29, 46, 82, 0.18);
    z-index: 5;
    animation: pop-in 0.16s ease;
  }
  .pop::after {
    content: '';
    position: absolute;
    bottom: -7px;
    right: 34px;
    width: 12px;
    height: 12px;
    background: var(--card);
    border-right: 1.5px solid rgba(228, 87, 46, 0.35);
    border-bottom: 1.5px solid rgba(228, 87, 46, 0.35);
    transform: rotate(45deg);
  }
  @keyframes pop-in { from { transform: translateY(6px); opacity: 0; } to { transform: none; opacity: 1; } }

  .pop-kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pen);
  }
  .pop-text { margin-top: 8px; font-size: 0.9rem; line-height: 1.6; color: var(--ink-soft); }

  #buy-note {
    position: absolute;
    width: 300px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 12px;
    padding: 14px 16px;
    font-size: 0.9rem;
    line-height: 1.55;
    box-shadow: 0 14px 34px rgba(29, 46, 82, 0.3);
    z-index: 60;
    animation: pop-in 0.16s ease;
  }

  .soon {
    margin-top: clamp(36px, 6vh, 52px);
    max-width: 640px;
    padding: 16px 20px;
    border-radius: 12px;
    border: 1px solid rgba(43, 74, 139, 0.14);
    background: var(--card);
    line-height: 1.6;
    color: var(--ink-soft);
  }
  .soon a { color: var(--pen); font-weight: 700; }

  @media (prefers-reduced-motion: reduce) {
    .item, .item:hover, .info-btn, .pop, #buy-note { transition: none; animation: none; transform: none; }
  }
</style>
